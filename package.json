{
  "name": "universal-dev-mcp",
  "version": "1.0.0",
  "description": "Universal MCP server that bridges AI tools to your local development application",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "mcp-switch": "./dist/cli/switch.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/server.js",
    "start:http": "node dist/http-server.js",
    "dev": "ts-node src/server.ts",
    "dev:http": "ts-node src/http-server.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-tools",
    "claude",
    "developer-tools",
    "llm",
    "localhost",
    "devtools",
    "typescript",
    "openai-compatible"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
